{
  "compilerOptions": {
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node", "vite/client", "react", "react-dom"],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@contracts/*": [
        "./contracts/*"
      ],
      "@db/*": [
        "./db/*"
      ]
    }
  },
  "include": [
    "src",
    "api",
    "contracts",
    "db"
  ]
}
